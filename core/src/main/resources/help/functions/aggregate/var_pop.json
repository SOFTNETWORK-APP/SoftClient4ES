{
  "name": "VAR_POP",
  "category": "Aggregate",
  "shortDescription": "Population variance of values",
  "syntax": [
    "VAR_POP(column)",
    "VAR_POP(column) OVER (PARTITION BY partition_expr, ...)"
  ],
  "description": "Computes the population variance (divides by n). Use when the input is the entire population, not a sample.",
  "parameters": [
    {
      "name": "column",
      "type": "NUMERIC",
      "description": "Numeric column",
      "optional": false,
      "defaultValue": null
    }
  ],
  "returnType": "DOUBLE",
  "examples": [
    {
      "title": "Population variance",
      "description": "Across all rows",
      "sql": "SELECT VAR_POP(salary) FROM emp"
    }
  ],
  "notes": [
    "Population variant — divides by n, not n-1.",
    "NULL values are ignored.",
    "Works on Elasticsearch 6+."
  ],
  "seeAlso": ["VARIANCE", "VAR_SAMP", "STDDEV_POP"],
  "aliases": []
}
